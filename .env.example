# Model Configuration
MODEL_PATH=models/
CHECKPOINT_DIR=checkpoints/

# Data Paths
DATA_RAW_PATH=data/raw/
DATA_PROCESSED_PATH=data/final/

# Risk Management
MAX_POSITION_SIZE=0.1
STOP_LOSS_PERCENT=0.02
TAKE_PROFIT_PERCENT=0.04