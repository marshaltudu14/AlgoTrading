# Fyers API Configuration
FYERS_APP_ID=your_app_id_here
FYERS_API_KEY=your_api_key_here
FYERS_ACCESS_TOKEN=your_access_token_here

# Database Configuration (if needed)
DATABASE_URL=sqlite:///trading.db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Logging
LOG_LEVEL=INFO
